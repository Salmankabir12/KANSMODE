# Public site URL
PUBLIC_SITE_URL=https://www.kansmode.com

# Sanity CMS (public read-only client)
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# Sanity write token (required for /admin quick create/edit)
# Create a token with Editor permissions at https://www.sanity.io/manage/present/project-id/api#tokens
SANITY_API_TOKEN=sk...

# Admin panel auth (required for /admin routes)
ADMIN_PASSWORD=change-me-in-production
ADMIN_SESSION_SECRET=any-long-random-string-min-32-chars

# Resend (used in local non-wrangler dev; in production set via wrangler secret)
RESEND_API_KEY=re_...
ADMIN_EMAIL=info@kansmode.com
FROM_EMAIL=contact@kansmode.com
