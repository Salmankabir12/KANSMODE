---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/astro/Container.astro';
import Section from '@/components/astro/Section.astro';
import { sanityClient } from '@/lib/sanity';
import { productCategoriesQuery, productSubcategoriesQuery } from '@/lib/queries';
import { placeholderCategories } from '@/data/placeholders';

const { category } = Astro.params;
const allCategoriesRaw = await sanityClient.fetch(productCategoriesQuery).catch(() => []);
const allCategories = allCategoriesRaw.length ? allCategoriesRaw : placeholderCategories;
const currentCategory = allCategories.find((c: any) => c.slug.current === category) || allCategories[0];

const allSubcategories = await sanityClient.fetch(productSubcategoriesQuery).catch(() => []);
const subcategories = allSubcategories.filter((s: any) => s.category._id === currentCategory?._id);
---

<BaseLayout title={`${currentCategory?.name || 'Products'} — Kans Mode International`}>
  <section class="bg-brand-navy py-20 text-white">
    <Container>
      <div class="max-w-2xl">
        <h1 class="text-4xl font-bold md:text-5xl">Products Information</h1>
        <nav class="mt-4 text-sm text-slate-300" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white">Home</a>
          <span class="mx-2">/</span>
          <a href="/products" class="hover:text-white">Products</a>
          <span class="mx-2">/</span>
          <span>{currentCategory?.name}</span>
        </nav>
      </div>
    </Container>
  </section>

  <Section>
    <Container>
      <div class="mb-12 text-center">
        <span class="text-sm font-semibold uppercase tracking-wider text-brand-blue">Our Products</span>
        <h2 class="mt-2 text-3xl font-bold text-brand-navy md:text-4xl">{currentCategory?.name} Subcategories</h2>
      </div>
      {subcategories.length === 0 ? (
        <div class="rounded-2xl border border-slate-200 bg-white p-12 text-center">
          <p class="text-slate-600">No subcategories found. <a href="/products" class="text-brand-blue hover:underline">Back to categories</a></p>
        </div>
      ) : (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {subcategories.map((sub: any) => (
            <a href={`/product/${currentCategory.slug.current}/${sub.slug.current}`} class="group overflow-hidden rounded-2xl border border-slate-200 bg-white transition hover:shadow-lg">
              <div class="aspect-[4/3] bg-slate-100"></div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-brand-navy group-hover:text-brand-blue">{sub.name}</h3>
              </div>
            </a>
          ))}
        </div>
      )}
    </Container>
  </Section>
</BaseLayout>
