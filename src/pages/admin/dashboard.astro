---
import Layout from '@/lib/admin/Layout.astro';
import { requireAdmin } from '@/lib/admin/auth-check';
import { sanityClient } from '@/lib/sanity';

await requireAdmin(Astro);

const types = [
  { name: 'heroBanner', title: 'Hero Banners', icon: '🖼' },
  { name: 'service', title: 'Services', icon: '⚡' },
  { name: 'productCategory', title: 'Product Categories', icon: '📁' },
  { name: 'productSubcategory', title: 'Product Subcategories', icon: '📂' },
  { name: 'product', title: 'Products', icon: '👕' },
  { name: 'teamMember', title: 'Team Members', icon: '👥' },
  { name: 'client', title: 'Clients', icon: '🤝' },
  { name: 'testimonial', title: 'Testimonials', icon: '⭐' },
  { name: 'post', title: 'Blog Posts', icon: '📝' },
];

const counts: Record<string, number> = {};
let messageCount = 0;

for (const t of types) {
  try {
    const result = await sanityClient.fetch(`count(*[_type == $type])`, { type: t.name });
    counts[t.name] = result ?? 0;
  } catch {
    counts[t.name] = 0;
  }
}

try {
  const runtime = (Astro.locals as any)?.runtime;
  const db = runtime?.env?.DB;
  if (db) {
    const result = await db.prepare('SELECT COUNT(*) as count FROM contacts').first();
    messageCount = result?.count ?? 0;
  }
} catch {}
---

<Layout title="Dashboard" currentSection="dashboard">
  <div class="grid gap-4 md:grid-cols-3 lg:grid-cols-4 mb-8">
    {types.map((t) => (
      <a
        href={`/admin/content/${t.name}`}
        class="rounded-xl border border-slate-800 bg-slate-900 p-5 transition hover:border-indigo-500/50 hover:bg-slate-800"
      >
        <div class="flex items-center justify-between mb-3">
          <span class="text-lg">{t.icon}</span>
          <span class="rounded-full bg-slate-800 px-3 py-1 text-sm font-medium text-slate-300">
            {counts[t.name] ?? 0}
          </span>
        </div>
        <h3 class="font-semibold">{t.title}</h3>
      </a>
    ))}

    <a
      href="/admin/messages"
      class="rounded-xl border border-slate-800 bg-slate-900 p-5 transition hover:border-indigo-500/50 hover:bg-slate-800"
    >
      <div class="flex items-center justify-between mb-3">
        <span class="text-lg">✉</span>
        <span class="rounded-full bg-slate-800 px-3 py-1 text-sm font-medium text-slate-300">
          {messageCount}
        </span>
      </div>
      <h3 class="font-semibold">Messages</h3>
    </a>
  </div>

  <div class="rounded-xl border border-slate-800 bg-slate-900 p-6">
    <h2 class="font-semibold mb-2">Quick Actions</h2>
    <div class="flex flex-wrap gap-3 mt-3">
      <a href="/admin/content/testimonial/new"
        class="rounded-lg bg-indigo-600/20 px-4 py-2 text-sm text-indigo-300 hover:bg-indigo-600/30 transition"
      >
        + Add Testimonial
      </a>
      <a href="/admin/content/product/new"
        class="rounded-lg bg-indigo-600/20 px-4 py-2 text-sm text-indigo-300 hover:bg-indigo-600/30 transition"
      >
        + Add Product
      </a>
      <a href="/admin/content/post/new"
        class="rounded-lg bg-indigo-600/20 px-4 py-2 text-sm text-indigo-300 hover:bg-indigo-600/30 transition"
      >
        + Add Blog Post
      </a>
      <a href="https://kansmode-cms.sanity.studio" target="_blank"
        class="rounded-lg bg-slate-800 px-4 py-2 text-sm text-slate-300 hover:bg-slate-700 transition"
      >
        Open Sanity Studio →
      </a>
    </div>
  </div>
</Layout>
