---
import { COOKIE_NAME, getSessionSecret, verifySession } from '@/lib/admin/auth';
import { sanityClient } from '@/lib/sanity';

const session = Astro.cookies.get(COOKIE_NAME)?.value;
const secret = getSessionSecret();
const isLoggedIn = secret ? await verifySession(session, secret) : false;

if (!isLoggedIn) {
  return Astro.redirect('/admin');
}

const type = Astro.url.searchParams.get('type') ?? 'testimonial';

const categories = await sanityClient.fetch(`*[_type == "productCategory"]{_id, name}`).catch(() => []);

const fields: Record<string, { name: string; label: string; type: 'text' | 'textarea' | 'number' | 'select' | 'datetime'; options?: { value: string; label: string }[]; required?: boolean }[]> = {
  testimonial: [
    { name: 'name', label: 'Name', type: 'text', required: true },
    { name: 'role', label: 'Role / Company', type: 'text' },
    { name: 'quote', label: 'Quote', type: 'textarea', required: true },
  ],
  client: [
    { name: 'name', label: 'Client Name', type: 'text', required: true },
  ],
  service: [
    { name: 'title', label: 'Title', type: 'text', required: true },
    { name: 'description', label: 'Description', type: 'textarea' },
    { name: 'order', label: 'Order', type: 'number' },
  ],
  teamMember: [
    { name: 'name', label: 'Name', type: 'text', required: true },
    { name: 'role', label: 'Role', type: 'text', required: true },
    { name: 'bio', label: 'Bio', type: 'textarea' },
    { name: 'order', label: 'Order', type: 'number' },
  ],
  productCategory: [
    { name: 'name', label: 'Name', type: 'text', required: true },
    { name: 'description', label: 'Description', type: 'textarea' },
  ],
  productSubcategory: [
    { name: 'name', label: 'Name', type: 'text', required: true },
    { name: 'description', label: 'Description', type: 'textarea' },
    { name: 'category', label: 'Category', type: 'select', required: true, options: categories.map((c: any) => ({ value: c._id, label: c.name })) },
  ],
  product: [
    { name: 'name', label: 'Name', type: 'text', required: true },
    { name: 'category', label: 'Category', type: 'select', required: true, options: categories.map((c: any) => ({ value: c._id, label: c.name })) },
    { name: 'price', label: 'Price', type: 'text' },
    { name: 'size', label: 'Size Range', type: 'text' },
  ],
  post: [
    { name: 'title', label: 'Title', type: 'text', required: true },
    { name: 'excerpt', label: 'Excerpt', type: 'textarea' },
    { name: 'publishedAt', label: 'Published At', type: 'datetime' },
  ],
  heroBanner: [
    { name: 'title', label: 'Title', type: 'text', required: true },
    { name: 'subtitle', label: 'Subtitle', type: 'text' },
    { name: 'link', label: 'Link', type: 'text' },
    { name: 'order', label: 'Order', type: 'number' },
  ],
};

const currentFields = fields[type] ?? fields.testimonial;
const typeOptions = Object.keys(fields);
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<!doctype html>
<html lang="en" class="bg-slate-950 text-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quick Create — Kans Mode Admin</title>
    <style>
      body { font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    </style>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-slate-800 bg-slate-900/80 px-6 py-4 backdrop-blur">
      <div class="mx-auto flex max-w-3xl items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/admin/dashboard" class="text-sm text-slate-400 hover:text-white">← Dashboard</a>
          <h1 class="text-xl font-bold">Quick Create</h1>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-10">
      {error && (
        <div class="mb-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-200">
          Failed to create document. {error}
        </div>
      )}
      {success && (
        <div class="mb-6 rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">
          Document created successfully.
        </div>
      )}

      <form method="GET" class="mb-8 flex items-center gap-3">
        <label class="text-sm text-slate-400">Content type</label>
        <select name="type" onchange="this.form.submit()" class="rounded-lg border border-slate-700 bg-slate-900 px-4 py-2 text-white outline-none focus:border-indigo-500">
          {typeOptions.map((t) => (
            <option value={t} selected={t === type}>{t}</option>
          ))}
        </select>
      </form>

      <form action="/api/admin/create" method="POST" class="space-y-5 rounded-xl border border-slate-800 bg-slate-900 p-6">
        <input type="hidden" name="type" value={type} />

        {currentFields.map((field) => (
          <div>
            <label for={field.name} class="mb-1 block text-sm font-medium text-slate-300">
              {field.label}
              {field.required && <span class="text-red-400">*</span>}
            </label>
            {field.type === 'textarea' ? (
              <textarea
                id={field.name}
                name={field.name}
                rows={4}
                required={field.required}
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
              />
            ) : field.type === 'select' ? (
              <select
                id={field.name}
                name={field.name}
                required={field.required}
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500"
              >
                <option value="">Select {field.label}</option>
                {field.options?.map((opt) => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
            ) : (
              <input
                id={field.name}
                name={field.name}
                type={field.type === 'number' ? 'number' : field.type === 'datetime' ? 'datetime-local' : 'text'}
                required={field.required}
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
              />
            )}
          </div>
        ))}

        <p class="text-xs text-slate-500">
          Images and rich text can be added later from Sanity Studio.
        </p>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="rounded-lg bg-indigo-600 px-5 py-2.5 font-semibold text-white transition hover:bg-indigo-500">
            Create {type}
          </button>
          <a href="/admin/dashboard" class="rounded-lg border border-slate-700 px-5 py-2.5 text-slate-300 transition hover:bg-slate-800 hover:text-white">
            Cancel
          </a>
        </div>
      </form>
    </main>
  </body>
</html>
