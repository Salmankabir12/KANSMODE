---
import Layout from '@/lib/admin/Layout.astro';
import { requireAdmin } from '@/lib/admin/auth-check';
import { sanityClient } from '@/lib/sanity';

await requireAdmin(Astro);

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`).catch(() => null);

function val(path: string): string {
  if (!settings) return '';
  if (path.startsWith('socialLinks.')) {
    const key = path.replace('socialLinks.', '');
    return settings.socialLinks?.[key] ?? '';
  }
  if (path === 'phones' && Array.isArray(settings.phones)) {
    return settings.phones.join(', ');
  }
  return settings[path]?.toString() ?? '';
}

const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<Layout title="Site Settings" currentSection="settings">
  {error && (
    <div class="mb-4 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm text-red-200">{error}</div>
  )}
  {success && (
    <div class="mb-4 rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-200">
      Settings saved successfully.
    </div>
  )}

  {!settings?._id ? (
    <div class="rounded-xl border border-slate-800 bg-slate-900 p-6 text-slate-400">
      No site settings document found. Create one in{' '}
      <a href="https://kansmode-cms.sanity.studio/desk/siteSettings" target="_blank" class="text-indigo-400 underline">
        Sanity Studio
      </a>{' '}
      first, then return here to edit.
    </div>
  ) : (
    <form action="/api/admin/content/update" method="POST" class="space-y-5 rounded-xl border border-slate-800 bg-slate-900 p-6 max-w-2xl">
      <input type="hidden" name="_type" value="siteSettings" />
      <input type="hidden" name="_id" value={settings._id} />

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Site Title</label>
        <input name="title" type="text" value={val('title')} required
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Description</label>
        <textarea name="description" rows={3}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500"
        >{val('description')}</textarea>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Address</label>
        <input name="address" type="text" value={val('address')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Email</label>
        <input name="email" type="email" value={val('email')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Office Hours</label>
        <input name="officeHours" type="text" value={val('officeHours')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Phone Numbers (comma separated)</label>
        <input name="phones" type="text" value={val('phones')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Facebook URL</label>
        <input name="socialLinks.facebook" type="url" value={val('socialLinks.facebook')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">LinkedIn URL</label>
        <input name="socialLinks.linkedin" type="url" value={val('socialLinks.linkedin')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">YouTube URL</label>
        <input name="socialLinks.youtube" type="url" value={val('socialLinks.youtube')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-slate-300">Twitter URL</label>
        <input name="socialLinks.twitter" type="url" value={val('socialLinks.twitter')}
          class="w-full rounded-lg border border-slate-700 bg-slate-950 px-4 py-3 text-white outline-none focus:border-indigo-500" />
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit"
          class="rounded-lg bg-indigo-600 px-5 py-2.5 font-semibold text-white transition hover:bg-indigo-500"
        >
          Save Settings
        </button>
      </div>
    </form>
  )}
</Layout>
