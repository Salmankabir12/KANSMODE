---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/astro/Container.astro';
import Section from '@/components/astro/Section.astro';
import Header from '@/components/svelte/layout/Header.svelte';
import Footer from '@/components/svelte/layout/Footer.svelte';
import { sanityClient } from '@/lib/sanity';
import { clientsQuery, testimonialsQuery } from '@/lib/queries';
import { placeholderClients, placeholderTestimonials } from '@/data/placeholders';
import FadeIn from '@/components/svelte/animations/FadeIn.svelte';
import StaggerChildren from '@/components/svelte/animations/StaggerChildren.svelte';
import StaggerItem from '@/components/svelte/animations/StaggerItem.svelte';
import TextReveal from '@/components/svelte/animations/TextReveal.svelte';
import SquaresBackground from '@/components/svelte/ui/SquaresBackground.svelte';

const clientsRaw = await sanityClient.fetch(clientsQuery).catch(() => []);
const testimonialsRaw = await sanityClient.fetch(testimonialsQuery).catch(() => []);
const clients = clientsRaw.length ? clientsRaw : placeholderClients;
const testimonials = testimonialsRaw.length ? testimonialsRaw : placeholderTestimonials;

const pathname = Astro.url.pathname;
---

<BaseLayout title="Our Clients — Kans Mode International">
  <Header pathname={pathname} client:load />
  <main id="main-content" class="relative z-10 bg-white">
  <section class="relative bg-brand-navy py-20 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <SquaresBackground direction="diagonal" speed={0.5} borderColor="rgba(255,255,255,0.08)" squareSize={50} client:load />
    </div>
    <Container>
      <div class="relative z-10 max-w-2xl">
        <h1 class="hero-animate hero-delay-1 text-4xl font-bold md:text-5xl">Clients Of Our Company</h1>
        <nav class="hero-animate hero-delay-2 mt-4 text-sm text-slate-300" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span>Our Clients</span>
        </nav>
      </div>
    </Container>
  </section>

  <Section>
    <Container>
      <FadeIn direction="up">
        <div class="mb-12 text-center">
          <span class="text-sm font-semibold uppercase tracking-wider text-brand-blue">Our Clients</span>
          <TextReveal text="Our Valued Partners Over the Globe" as="h2" class="mt-2 text-3xl font-bold text-brand-navy md:text-4xl" />
        </div>
      </FadeIn>
      <StaggerChildren staggerDelay={0.08}>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          {clients.map((client, i) => (
            <StaggerItem index={i}>
              <div class="group rounded-2xl border border-slate-200 bg-white p-8 text-center transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-brand-accent/30"
                onmousemove={(e) => {
                  const r = e.currentTarget.getBoundingClientRect();
                  const x = e.clientX - r.left, y = e.clientY - r.top;
                  const cx = r.width / 2, cy = r.height / 2;
                  e.currentTarget.style.transform = `perspective(1000px) rotateX(${((y - cy) / cy) * -4}deg) rotateY(${((x - cx) / cx) * 4}deg) scale3d(1.02, 1.02, 1.02)`;
                }}
                onmouseleave={(e) => {
                  e.currentTarget.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
                }}
                style="transform-style: preserve-3d;">
                <div class="mx-auto mb-4 h-20 w-20 overflow-hidden rounded-full bg-slate-100 ring-2 ring-slate-200 transition-all duration-300 group-hover:ring-brand-accent/50">
                  {client.image && <img src={client.image} alt={client.name} class="h-full w-full object-cover" />}
                </div>
                <h3 class="text-lg font-bold text-brand-navy group-hover:text-brand-blue transition-colors">{client.name}</h3>
                {client.role && <p class="mt-1 text-sm text-slate-500">{client.role}</p>}
              </div>
            </StaggerItem>
          ))}
        </div>
      </StaggerChildren>
    </Container>
  </Section>

  <Section class="bg-surface-elevated">
    <Container>
      <FadeIn direction="up">
        <div class="mb-12 text-center">
          <span class="text-sm font-semibold uppercase tracking-wider text-brand-blue">Top Client's Review</span>
          <TextReveal text="What Clients Are Saying About Us" as="h2" class="mt-2 text-3xl font-bold text-brand-navy md:text-4xl" delay={0.1} />
        </div>
      </FadeIn>
      <StaggerChildren staggerDelay={0.1}>
        <div class="grid gap-6 md:grid-cols-2">
          {testimonials.map((t, i) => (
            <StaggerItem index={i}>
              <div class="rounded-2xl border border-slate-200 bg-white p-8 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5">
                <svg class="mb-4 h-8 w-8 text-brand-accent/30" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                </svg>
                <p class="mb-6 text-slate-600 leading-relaxed">"{t.quote}"</p>
                <div class="flex items-center gap-4">
                  <div class="h-12 w-12 overflow-hidden rounded-full bg-slate-200 ring-2 ring-slate-100">
                    {t.image && <img src={t.image} alt={t.name} class="h-full w-full object-cover" />}
                  </div>
                  <div>
                    <p class="font-bold text-brand-navy">{t.name}</p>
                    <p class="text-sm text-slate-500">{t.role}</p>
                  </div>
                </div>
              </div>
            </StaggerItem>
          ))}
        </div>
      </StaggerChildren>
    </Container>
  </Section>
  </main>
  <Footer client:load />
</BaseLayout>
