---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/astro/Container.astro';
---

<BaseLayout title="Page Not Found — Kans Mode International">
  <section class="flex min-h-[60vh] items-center justify-center py-20">
    <Container>
      <div class="text-center">
        <h1 class="text-6xl font-bold text-brand-navy">404</h1>
        <h2 class="mt-4 text-2xl font-semibold text-slate-800">Page Not Found</h2>
        <p class="mx-auto mt-4 max-w-md text-slate-600">The page you are looking for might have been removed or is temporarily unavailable.</p>
        <a href="/" class="mt-8 inline-block rounded-full bg-brand-navy px-8 py-3 font-semibold text-white transition hover:bg-slate-800">
          Back to Home
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>
