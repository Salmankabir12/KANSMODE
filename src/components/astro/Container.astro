---
interface Props {
  size?: "default" | "narrow" | "wide";
  class?: string;
}

const { size = "default", class: className } = Astro.props;

const sizeClasses = {
  narrow: "max-w-4xl",
  default: "max-w-7xl",
  wide: "max-w-[1400px]",
};
---

<div class:list={["mx-auto w-full px-4 sm:px-6 lg:px-8", sizeClasses[size], className]}>
  <slot />
</div>
