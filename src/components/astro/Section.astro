---
import SquaresBackground from '@/components/svelte/ui/SquaresBackground.svelte';

interface Props {
  variant?: "default" | "secondary" | "dark";
  padding?: "sm" | "default" | "lg";
  class?: string;
}

const { variant = "default", padding = "default", class: className } = Astro.props;

const paddingClasses = {
  sm: "py-12 md:py-16",
  default: "py-16 md:py-24",
  lg: "py-24 md:py-32",
};

const variantClasses = {
  default: "bg-bg-primary",
  secondary: "bg-bg-secondary",
  dark: "bg-brand-navy text-text-inverse",
};
---

<section class:list={["relative w-full overflow-hidden", paddingClasses[padding], variantClasses[variant], className]}>
  {variant === "dark" && (
    <>
      <div class="absolute inset-0 bg-brand-navy/60 z-0 pointer-events-none" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,rgba(26,39,68,0.8)_80%,rgba(26,39,68,1)_100%)] z-0 mix-blend-multiply pointer-events-none" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-navy/40 via-transparent to-brand-navy z-0 pointer-events-none" />
      
      <div class="absolute inset-0 opacity-40 mix-blend-screen pointer-events-auto">
        <SquaresBackground
          client:visible
          direction="diagonal"
          speed={0.4}
          squareSize={40}
          borderColor="rgba(255,255,255,0.12)"
          hoverFillColor="rgba(233,69,96,0.12)"
        />
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/8 to-transparent pointer-events-none" />
    </>
  )}
  {variant === "default" && (
    <div class="absolute bottom-0 right-0 w-64 h-64 dot-grid-dark opacity-30 pointer-events-none" />
  )}
  <slot />
</section>
