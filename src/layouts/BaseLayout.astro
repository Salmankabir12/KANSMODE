---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Kans Mode International', description = '100% export oriented readymade garments buying house company based in Bangladesh.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a2744" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-slate-900 antialiased">
    <slot />
  </body>
</html>

<script>
  try {
    const { default: Lenis } = await import('lenis');
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      smoothWheel: true,
      wheelMultiplier: 1,
      touchMultiplier: 2,
    });
    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  } catch (e) {
    console.warn('Lenis init failed:', e);
  }
</script>
